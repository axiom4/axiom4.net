{
  "name": "axiom4-web",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --inline-style-language css && node scripts/purge-css.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:api": "openapi-generator-cli generate  -p supportsES6=true,withInterfaces=true,useSingleRequestParameter=true -i http://127.0.0.1:8000/openapi -g typescript-angular -o src/app/modules/core/api/v1"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.7",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/router": "^22.0.7",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "localstorage-polyfill": "^1.0.1",
    "marked": "^18.0.6",
    "mermaid": "^11.16.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@angular/localize": "^22.0.7",
    "@openapitools/openapi-generator-cli": "^2.40.0",
    "@types/bootstrap": "^5.2.11",
    "@types/node": "^26.1.1",
    "@types/prismjs": "^1.26.6",
    "istanbul-lib-instrument": "^6.0.3",
    "purgecss": "^8.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "@openapitools/openapi-generator-cli@2.39.1": true,
    "@parcel/watcher@2.5.6": true,
    "fsevents@2.3.3": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
